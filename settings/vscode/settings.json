{
    "editor.fontSize": 14,
    "editor.fontFamily": "IBM Plex Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.tabSize": 2,
    "editor.smoothScrolling": true,
    "editor.minimap.showSlider": "always",
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.fastScrollSensitivity": 20,
    "editor.linkedEditing": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "always",
        "source.sortImports": "explicit",
        "source.sortAndRemoveImports": "explicit"
    },
    "editor.fontVariations": false,
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "[ruby]": {
        "editor.defaultFormatter": "Shopify.ruby-lsp"
    },
    "[go]": {
        "editor.defaultFormatter": "golang.go"
    },
    "[svelte]": {
        "editor.defaultFormatter": "svelte.svelte-vscode"
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 2,
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "workbench.editor.showTabs": "none",
    "workbench.editorAssociations": {
        "*.md": "vscode.markdown.preview.editor"
    },
    "workbench.colorTheme": "eyeshield",
    "workbench.colorCustomizations": {
        "editorCursor.foreground": "#000000",
    },
    "workbench.tree.expandMode": "singleClick",
    "workbench.list.typeNavigationMode": "automatic",
    "workbench.statusBar.visible": false,
    "workbench.editor.focusRecentEditorAfterClose": false,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "makefile.configureOnOpen": false,
    "files.associations": {
        "*.css": "tailwindcss",
        "*.yml.erb": "yaml"
    },
    "tailwindCSS.includeLanguages": {
        "liquid": "liquid"
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        ".direnv": true
    },
    "svelte.enable-ts-plugin": true,
    "go.toolsManagement.autoUpdate": true,
    "amp.tools.disable": [
        "mcp__Shopify__fetch_full_docs",
        "mcp__Shopify__introspect_graphql_schema",
        "mcp__Shopify__learn_shopify_api",
        "mcp__Shopify__search_docs_chunks",
        "mcp__Shopify__validate_graphql_codeblocks"
    ],
    "amp.mcpServers": {},
    "vim.easymotion": true,
    "vim.surround": true,
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.ignorecase": true,
    "vim.smartcase": true,
    "vim.leader": " ",
    "vim.scroll": 29,
    "vim.handleKeys": {
        "<C-c>": false,
        "<C-v>": false,
        "<C-x>": false
    },
    "vim.normalModeKeyBindings": [
        {
            "before": [
                "s"
            ],
            "commands": [
                "actions.find"
            ]
        },
        {
            "before": [
                "g",
                "h"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        },
        {
            "before": [
                "<Left>"
            ],
            "after": [
                "<C-w>",
                "h"
            ]
        },
        {
            "before": [
                "<Down>"
            ],
            "after": [
                "<C-w>",
                "j"
            ]
        },
        {
            "before": [
                "<Up>"
            ],
            "after": [
                "<C-w>",
                "k"
            ]
        },
        {
            "before": [
                "Y"
            ],
            "after": [
                "y",
                "y"
            ]
        },
        {
            "before": [
                "z"
            ],
            "after": [
                "z",
                "z"
            ]
        },
        {
            "before": [
                "j"
            ],
            "after": [
                "g",
                "j"
            ]
        },
        {
            "before": [
                "F"
            ],
            "commands": [
                "workbench.action.quickTextSearch"
            ]
        },
        {
            "before": [
                "k"
            ],
            "after": [
                "g",
                "k"
            ]
        },
        {
            "before": [
                "<C-d>"
            ],
            "after": [
                "<C-d>",
                "z",
                "z"
            ]
        },
        {
            "before": [
                "<C-u>"
            ],
            "after": [
                "<C-u>",
                "z",
                "z"
            ]
        },
        {
            "before": [
                "D"
            ],
            "after": [
                "\"",
                "_",
                "d",
                "d"
            ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                "<Tab>"
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },
        {
            "before": [
                "<S-Tab>"
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "p"
            ],
            "after": [
                "p",
                "g",
                "v",
                "y"
            ]
        },
        {
            "before": [
                "x"
            ],
            "after": [
                "\"",
                "_",
                "x"
            ]
        },
        {
            "before": [
                "d"
            ],
            "after": [
                "\"",
                "_",
                "d"
            ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "x"
            ],
            "after": [
                "\"",
                "_",
                "x"
            ]
        },
        {
            "before": [
                "d"
            ],
            "after": [
                "\"",
                "_",
                "d"
            ]
        },
        {
            "before": [
                "<esc>"
            ],
            "commands": [
                ":noh",
                "workbench.action.focusActiveEditorGroup"
            ]
        }
    ],
    "git.openRepositoryInParentFolders": "never",
    "amp.permissions": [
        {
            "tool": "Bash",
            "action": "ask",
            "matches": {
                "cmd": [
                    "*rm*rf*",
                    "*find*exec*",
                    "*find*delete*",
                    "*git*push*"
                ]
            }
        },
        {
            "tool": "*",
            "action": "allow",
            "matches": {}
        },
        {
            "tool": "Bash",
            "action": "ask",
            "matches": {
                "cmd": [
                    "*rm*rf*",
                    "*find*exec*",
                    "*find*delete*",
                    "*git*push*"
                ]
            }
        },
        {
            "tool": "*",
            "action": "allow",
            "matches": {}
        },
        {
            "tool": "Bash",
            "action": "ask",
            "matches": {
                "cmd": [
                    "*rm*rf*",
                    "*find*exec*",
                    "*find*delete*",
                    "*git*push*"
                ]
            }
        },
        {
            "tool": "*",
            "action": "allow",
            "matches": {}
        },
        {
            "tool": "Bash",
            "action": "allow",
            "matches": {
                "cmd": "cd newsletter && go test -v ./app -run TestRun"
            }
        },
        {
            "tool": "Bash",
            "matches": {
                "cmd": "make"
            },
            "action": "allow"
        }
    ],
    "zig.zls.enabled": "on",
    "breadcrumbs.enabled": false,
    "[erb]": {
        "editor.defaultFormatter": "Shopify.ruby-lsp"
    },
    "debug.onTaskErrors": "debugAnyway",
    "amp.tryOpus": true,
    "[swift]": {
        "editor.defaultFormatter": "sswg.swift-lang"
    },
    "C_Cpp.intelliSenseEngine": "disabled",
    "workbench.panel.showLabels": false,
    "[templ]": {
        "editor.defaultFormatter": "a-h.templ"
    },
    "files.exclude": {
        ".dockerignore": true,
        ".playwright-cli": true,
        "**/.direnv": true,
        "**/.jj": true,
        "**/.vscode": true,
        "bin/": true,
        "flake.lock": true,
        "go.sum": true,
        "result/": true
    },
    "task.allowAutomaticTasks": "on",
    "window.autoDetectColorScheme": false,
    "chat.titleBar.openInAgentsWindow.enabled": false,
    "workbench.browser.showInTitleBar": true,
    "chat.titleBar.signIn.enabled": false,
    "editor.minimap.enabled": false,
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "workbench.activityBar.location": "bottom",
    "terminal.external.osxExec": "Ghostty.app",
    "mermaidChart.showGenerateDiagramCodeLens": false
}