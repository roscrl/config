#!/usr/bin/env zsh
set -euo pipefail

search="no""checkin"
files=(${(f)"$(git diff --cached --name-only --diff-filter=ACMR)"})
(( ${#files} )) || exit 0

matches=$(git grep --cached -n -i --color=always -e "$search" -- "${files[@]}" || true)

if [[ -n "$matches" ]]; then
  count=$(print -r -- "$matches" | cut -d: -f1 | sort -u | wc -l | tr -d ' ')
  print -P "%B%F{red}Error:%f%b $search found in $count staged file(s) — aborting commit:"
  print -r -- "$matches"
  exit 1
fi
